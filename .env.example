DATABASE_URL=postgresql://localhost:5432/gacc
GACC_TEST_DATABASE_URL=postgresql://localhost:5432/gacc_test

# LLM backend (global default): ollama | claude_cli | claude_api
LLM_BACKEND=ollama
# Per-role overrides (optional). Leave unset and BOTH the heavier 'leads'
# framing step and the portal 'takes' use the global LLM_BACKEND above. Set
# these to split them — e.g. run leads locally on Ollama while takes run on
# Claude. Model is per-role too; unset → the backend's own default.
#   LLM_LEADS_BACKEND=ollama
#   LLM_LEADS_MODEL=qwen3.6:latest
#   LLM_TAKES_BACKEND=claude_api
#   LLM_TAKES_MODEL=claude-opus-4-8

# Use 127.0.0.1 explicitly — not `localhost`. On macOS `localhost` resolves
# to both ::1 (IPv6) and 127.0.0.1 (IPv4); httpx tries ::1 first. If anything
# else is listening on [::1]:11434 (Docker Desktop's port forwarder is a
# common culprit), requests get hijacked and return 404 on every chat. The
# host-native Ollama daemon binds IPv4-only.
OLLAMA_HOST=http://127.0.0.1:11434
# qwen3.6:latest is the working default. qwen3.5:9b returns empty content
# with `think=False` (model-side bug in current Ollama). Smaller models
# (mistral:latest, llama3.2:latest) work but have lower instruction-
# following rigour — expect more verifier rejections.
OLLAMA_MODEL=qwen3.6:latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Google Sheets export (service account)
GOOGLE_SHEETS_CREDENTIALS_PATH=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Optional override for the outbound User-Agent — please identify yourself
# to GACC if running anything beyond local one-shot tests.
USER_AGENT=gacc-monitor/0.1

LOG_LEVEL=INFO

# Google Chat (Spaces) incoming-webhook URL for `--notify-chat`. When set, a
# routine run that ingested new data from any source (Eurostat/HMRC/GACC) posts
# a message to the Space. Unset → --notify-chat is a no-op (logs and exits), so
# the routine step is harmless on machines without a webhook configured. The
# URL embeds key+token secrets — keep it in .env (gitignored), never commit it.
MERIDIAN_CHAT_WEBHOOK=
