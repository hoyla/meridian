DATABASE_URL=postgresql://localhost:5432/gacc
GACC_TEST_DATABASE_URL=postgresql://localhost:5432/gacc_test

# LLM backend: ollama | gemini
LLM_BACKEND=ollama

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Google Sheets export (service account)
GOOGLE_SHEETS_CREDENTIALS_PATH=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Optional override for the outbound User-Agent — please identify yourself
# to GACC if running anything beyond local one-shot tests.
USER_AGENT=gacc-monitor/0.1

LOG_LEVEL=INFO
